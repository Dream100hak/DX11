# 모든 텍스트 파일은 UTF-8로 저장
* text=auto encoding=utf-8

# 마크다운
*.md text eol=lf encoding=utf-8

# C++ 소스
*.h   text eol=crlf encoding=utf-8
*.cpp text eol=crlf encoding=utf-8

# HLSL 셰이더
*.hlsl  text eol=crlf encoding=utf-8
*.hlsli text eol=crlf encoding=utf-8
*.fx    text eol=crlf encoding=utf-8

# 프로젝트/솔루션 파일
*.sln     text eol=crlf encoding=utf-8
*.vcxproj text eol=crlf encoding=utf-8

# 바이너리 파일 (변환 없음)
*.lib binary
*.dll binary
*.pdb binary
*.cso binary
*.png binary
*.jpg binary
*.dds binary
*.fbx binary
*.mesh binary
*.mat  binary
*.clip binary
